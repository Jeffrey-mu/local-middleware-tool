{
  "name": "aigate",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "npm run tauri:dev",
    "dev:ui": "vite",
    "dev:gateway:rust": "cargo run --manifest-path src-tauri/Cargo.toml --bin aigate-gateway",
    "build:gateway": "node scripts/build-gateway-sidecar.mjs",
    "gateway": "npm run gateway:rust",
    "gateway:rust": "cargo run --manifest-path src-tauri/Cargo.toml --bin aigate-gateway",
    "tauri": "tauri",
    "tauri:dev": "concurrently \"npm:dev:gateway:rust\" \"tauri dev\"",
    "tauri:build": "npm run build:gateway && tauri build",
    "tauri:build:win": "npm run build:gateway && tauri build --bundles nsis",
    "build": "tsc -b && vite build",
    "lint": "oxlint",
    "preview": "vite preview"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.11.1",
    "concurrently": "^10.0.3",
    "lucide-react": "^1.23.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.2",
    "@tauri-apps/cli": "^2.11.4",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "esbuild": "^0.28.1",
    "oxlint": "^1.71.0",
    "tailwindcss": "^4.3.2",
    "typescript": "~6.0.2",
    "vite": "^8.1.1"
  }
}
