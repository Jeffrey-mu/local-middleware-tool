{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "CCSwitch",
  "version": "0.1.0",
  "identifier": "dev.local.ccswitch",
  "build": {
    "beforeDevCommand": "npm run dev:ui",
    "beforeBuildCommand": "npm run build:gateway && npm run build",
    "devUrl": "http://localhost:8788",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "CCSwitch",
        "width": 1280,
        "height": 820,
        "minWidth": 1040,
        "minHeight": 680,
        "center": true,
        "resizable": true,
        "maximizable": true,
        "minimizable": true,
        "closable": true,
        "decorations": true,
        "visible": true,
        "focus": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": [
      "../data/model-pricing.json"
    ],
    "externalBin": [
      "binaries/ccswitch-gateway"
    ],
    "icon": [
      "icons/icon.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
