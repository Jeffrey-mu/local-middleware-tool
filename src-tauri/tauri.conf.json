{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "CCSwitch",
  "version": "0.1.0",
  "identifier": "dev.local.ccswitch",
  "build": {
    "beforeDevCommand": "npm run dev:ui",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:8788",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "CCSwitch",
        "width": 1280,
        "height": 820,
        "minWidth": 980,
        "minHeight": 680,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
